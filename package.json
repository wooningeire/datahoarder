{
	"name": "@vaie/datahoarder",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"svelte": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"svelte": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./base": {
			"types": "./src/base.ts",
			"default": "./src/base.ts"
		},
		"./local-vault": {
			"types": "./src/local-vault.ts",
			"default": "./src/local-vault.ts"
		},
		"./markdown-preprocess": "./src/markdown-preprocess.js",
		"./markdown-preprocess.js": "./src/markdown-preprocess.js",
		"./markdown-render": {
			"types": "./src/markdown-render.ts",
			"default": "./src/markdown-render.ts"
		},
		"./note-tree": {
			"types": "./src/note-tree.ts",
			"default": "./src/note-tree.ts"
		},
		"./paths": {
			"types": "./src/paths.ts",
			"default": "./src/paths.ts"
		},
		"./raw-notes": {
			"types": "./src/raw-notes.ts",
			"default": "./src/raw-notes.ts"
