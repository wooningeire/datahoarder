	},
	"files": [
		"src",
		"README.md"
	],
	"peerDependencies": {
		"svelte": "^5.45.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
