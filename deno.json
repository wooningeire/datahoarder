{
	"nodeModulesDir": "auto",
	"imports": {
		"@sveltejs/acorn-typescript": "npm:@sveltejs/acorn-typescript@1.0.10",
		"@jridgewell/gen-mapping": "npm:@jridgewell/gen-mapping@0.3.13",
		"@jridgewell/remapping": "npm:@jridgewell/remapping@2.3.5",
		"@jridgewell/resolve-uri": "npm:@jridgewell/resolve-uri@3.1.2",
		"@jridgewell/sourcemap-codec": "npm:@jridgewell/sourcemap-codec@1.5.5",
		"@jridgewell/trace-mapping": "npm:@jridgewell/trace-mapping@0.3.31",
		"@playwright/test": "npm:@playwright/test@1.57.0",
		"@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@3.0.10",
		"@sveltejs/kit/": "npm:@sveltejs/kit@2.61.1/",
		"@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@7.1.2",
		"@vitest/browser-playwright": "npm:@vitest/browser-playwright@4.1.5",
		"acorn": "npm:acorn@8.16.0",
		"aria-query": "npm:aria-query@5.3.1",
		"axobject-query": "npm:axobject-query@4.1.0",
		"clsx": "npm:clsx@2.1.1",
		"cookie": "npm:cookie@0.6.0",
		"devalue": "npm:devalue@5.8.1",
		"esrap": "npm:esrap@2.2.9",
		"esrap/languages/ts": "npm:esrap@2.2.9/languages/ts",
		"esrap/": "npm:esrap@2.2.9/",
		"magic-string": "npm:magic-string@0.30.21",
		"mdsvex": "npm:mdsvex@0.12.7",
		"is-reference": "npm:is-reference@3.0.3",
		"locate-character": "npm:locate-character@3.0.0",
		"monaco-editor": "npm:monaco-editor@0.55.1",
		"set-cookie-parser": "npm:set-cookie-parser@3.1.0",
		"svelte": "npm:svelte@5.56.1",
		"svelte/": "npm:svelte@5.56.1/",
		"typescript": "npm:typescript@6.0.3",
		"vitest": "npm:vitest@4.1.5",
		"vitest/": "npm:vitest@4.1.5/",
		"vitest-browser-svelte": "npm:vitest-browser-svelte@2.1.1",
		"zimmerframe": "npm:zimmerframe@1.1.4"
	},
	"tasks": {
		"dev": "deno run -A npm:vite dev",
		"dev:folder": "deno run -A scripts/open-folder-dev.ts",
		"dev:folder:deno": "deno task dev:folder",
		"sync": "deno run -A npm:@sveltejs/kit sync",
		"build:app": "deno run -A npm:vite build",
		"preview": "deno run -A npm:vite preview",
		"tauri": "deno run -A scripts/tauri.ts",
		"convert:obsidian-bases": "deno run -A --sloppy-imports scripts/convert-obsidian-bases.ts",
		"convert:collections-to-ts": "deno run -A --sloppy-imports scripts/convert-collections-to-ts.ts",
		"verify:collection-ts-conversion": "deno run -A --sloppy-imports scripts/verify-collection-ts-conversion.ts",
		"prepack": "deno task sync && deno run -A npm:@sveltejs/package",
		"build": "deno task build:app && deno task prepack",
		"check": "deno task sync && deno run -A npm:svelte-check --tsconfig ./tsconfig.json && deno task check:source-size",
		"check:source-size": "deno run --allow-read scripts/check-source-file-size.ts",
		"check:ui-size": "deno task check:source-size",
		"check:watch": "deno task sync && deno run -A npm:svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "deno run -A npm:vitest",
		"test": "deno task test:unit --run && deno task test:e2e",
		"test:e2e": ".\\node_modules\\.bin\\playwright.cmd test"
	}
}
