{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Datahoarder",
  "version": "0.1.0",
  "identifier": "art.vaie.datahoarder",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://127.0.0.1:5191",
    "beforeDevCommand": "deno run -A ./scripts/tauri-before-dev.ts --host 127.0.0.1 --port 5191",
    "beforeBuildCommand": "deno task build:app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Datahoarder",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
